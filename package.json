{
  "name": "@getbud-co/buds",
  "version": "0.3.0",
  "type": "module",
  "description": "BUDS — componentes React para a plataforma Bud",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "build:lib": "npm run typecheck && vite build --config vite.config.lib.ts",
    "build:docs": "tsc -b && vite build",
    "sync-version": "node -e \"const p=require('./package.json');const f=require('fs');const j=JSON.parse(f.readFileSync('public/buds.json','utf8'));j.version=p.version;f.writeFileSync('public/buds.json',JSON.stringify(j,null,2)+'\\n')\"",
    "verify": "npm run sync-version && npm run lint && npm run typecheck && npm run test:run && npm run build:docs && npm run build:lib",
    "prepublishOnly": "npm run sync-version && npm run build:lib",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@phosphor-icons/react": "^2.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@fontsource/crimson-pro": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@microsoft/api-extractor": "^7.57.7",
    "@phosphor-icons/react": "^2.1.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "recharts": "^3.8.0"
  }
}
