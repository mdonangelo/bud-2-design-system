{
  "name": "@getbud-co/buds-vanilla",
  "version": "0.1.0",
  "type": "module",
  "description": "BUDS — Web Components para uso multi-framework",
  "main": "./dist/buds.iife.js",
  "module": "./dist/buds.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/buds.js",
      "require": "./dist/buds.iife.js"
    },
    "./styles": "./dist/buds.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.8",
    "jsdom": "^27.2.0"
  }
}
